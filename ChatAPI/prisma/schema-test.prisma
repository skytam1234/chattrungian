// Test Prisma schema using SQLite
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  username        String   @unique
  email           String   @unique
  passwordHash    String   @map("password_hash")
  displayName     String   @map("display_name")
  avatarUrl       String?
  phoneNumber     String?  @unique @map("phone_number")
  status          String   @default("offline") @map("status")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  isActive        Boolean  @default(true) @map("is_active")
  isVerified      Boolean  @default(false) @map("is_verified")
  verificationToken String? @map("verification_token")
  resetToken      String?  @map("reset_token")
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sessions            Session[]
  sentMessages        Message[]              @relation("SentMessages")
  conversationUsers   ConversationUser[]
  messageStatuses     MessageStatus[]
  unreadMessages      UnreadMessage[]
  pinnedDocuments     PinnedDocument[]       @relation("PinnedBy")
  groupMembers        GroupMember[]
}

model Session {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  token             String   @unique
  refreshToken      String?  @map("refresh_token")
  deviceInfo        String   @default("{}") @map("device_info")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  expiresAt         DateTime @map("expires_at")
  refreshExpiresAt  DateTime? @map("refresh_expires_at")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String   @id @default(uuid())
  type            String
  name            String?
  avatarUrl       String?  @map("avatar_url")
  description     String?
  createdBy       String   @map("created_by")
  lastMessageId   String?  @map("last_message_id")
  lastMessageAt   DateTime? @map("last_message_at")
  isArchived      Boolean  @default(false) @map("is_archived")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users           ConversationUser[]
  messages        Message[]
  pinnedDocuments PinnedDocument[]
  unreadMessages  UnreadMessage[]
  groupMembers   GroupMember[]
}

model ConversationUser {
  id                  String   @id @default(uuid())
  conversationId      String   @map("conversation_id")
  userId              String   @map("user_id")
  nickname            String?
  role                String   @default("member")
  joinedAt            DateTime @default(now()) @map("joined_at")
  leftAt              DateTime? @map("left_at")
  isMuted             Boolean  @default(false) @map("is_muted")
  isPinned            Boolean  @default(false) @map("is_pinned")
  notifications       String   @default("all")
  customNotification  Boolean  @default(false) @map("custom_notification")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  senderId        String   @map("sender_id")
  content         String?
  messageType     String   @default("text") @map("message_type")
  metadata        String   @default("{}")
  replyToId       String?  @map("reply_to_id")
  forwardedFromId String?  @map("forwarded_from_id")
  isEdited        Boolean  @default(false) @map("is_edited")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  isRecalled      Boolean  @default(false) @map("is_recalled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
  replyTo      Message?     @relation("ReplyMessages", fields: [replyToId], references: [id])
  replies      Message[]    @relation("ReplyMessages")
  statuses     MessageStatus[]
  pinnedDocs   PinnedDocument[]
}

model MessageStatus {
  id          String   @id @default(uuid())
  messageId   String   @map("message_id")
  userId      String   @map("user_id")
  status      String   @default("sent")
  seenAt      DateTime? @map("seen_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model UnreadMessage {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  conversationId      String   @map("conversation_id")
  lastReadMessageId   String?  @map("last_read_message_id")
  unreadCount         Int      @default(0) @map("unread_count")
  lastUnreadAt        DateTime? @map("last_unread_at")
  hasUnreplied        Boolean  @default(false) @map("has_unreplied")
  lastUnrepliedMsgId  String?  @map("last_unreplied_msg_id")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

model PinnedDocument {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  messageId       String   @map("message_id")
  pinnedBy        String   @map("pinned_by")
  title           String?
  description     String?
  pinnedAt        DateTime @default(now()) @map("pinned_at")
  pinOrder        Int      @default(0) @map("pin_order")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser User         @relation("PinnedBy", fields: [pinnedBy], references: [id])

  @@unique([conversationId, messageId])
}

model GroupMember {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  role           String   @default("member")
  nickname       String?
  joinedAt       DateTime @default(now()) @map("joined_at")
  invitedBy      String?  @map("invited_by")
  isActive       Boolean  @default(true) @map("is_active")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}
